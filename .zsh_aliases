alias v='nvim'
alias vi='nvim'
alias vim='nvim'

# yarn
alias y='yarn'
alias ya='yarn add'
alias yd='yarn dev'
alias ys='yarn start'

# npm
alias ni='npm install'
alias nr='npm run'

# terraform
alias tf='terraform'
alias tfw='terraform workspace'
alias tfs='terraform state'

# kubecm
alias kc='kubecm'

# exa
alias ls='eza'
alias la='eza -al'

# opencode
alias oc='opencode'

# ccusage
alias ccusage-codex='bunx @ccusage/codex@latest'

# claude code
alias cc-codex="$HOME/.local/bin/claude --settings ~/.claude/settings-codex.json"
alias cc-bedrock="$HOME/.local/bin/claude --settings ~/.claude/settings-bedrock.json"
alias claude='cc-codex'

